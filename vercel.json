{
  "buildCommand": "npm run build",
  "outputDirectory": "../dist",
  "framework": "vite",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/portfolio",
      "destination": "/index.html"
    },
    {
      "source": "/portfolio/",
      "destination": "/index.html"
    },
    {
      "source": "/portfolio/:path*",
      "destination": "/index.html"
    }
  ]
}
